        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件沒有目錄。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類には目次がありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 문서에는 목차가 없습니다."
