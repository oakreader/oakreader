    "The agent will no longer remember this. This can't be undone.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体将不再记住此内容。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "智能體將不再記住此內容。此操作無法復原。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントはこれを記憶しなくなります。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트가 더 이상 이 내용을 기억하지 않습니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Agent merkt sich dies nicht mehr. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’agent ne s’en souviendra plus. Cette action est irréversible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El agente ya no recordará esto. Esta acción no se puede deshacer."
          }
        }
      }
    },
    "The document passed all accessibility checks.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文稿已通过所有辅助功能检查。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件已通過所有輔助使用檢查。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類はすべてのアクセシビリティチェックに合格しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "문서가 모든 손쉬운 사용 검사를 통과했습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Dokument hat alle Prüfungen der Bedienungshilfen bestanden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le document a réussi toutes les vérifications d’accessibilité."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El documento superó todas las comprobaciones de accesibilidad."
          }
        }
      }
    },
    "The quick brown fox jumps over the lazy dog": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "敏捷的棕色狐狸跃过懒狗"
