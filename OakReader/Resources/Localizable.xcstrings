          "stringUnit": {
            "state": "translated",
            "value": "復元したライブラリを読み込むには、OakReader を再起動する必要があります。以前のデータは別のフォルダに保存されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복원된 라이브러리를 로드하려면 OakReader를 다시 시작해야 합니다. 이전 데이터는 별도의 폴더에 보존되었습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "OakReader muss neu gestartet werden, um die wiederhergestellte Mediathek zu laden. Ihre vorherigen Daten wurden in einem separaten Ordner aufbewahrt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "OakReader doit redémarrer pour charger la bibliothèque restaurée. Vos données précédentes ont été conservées dans un dossier séparé."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "OakReader necesita reiniciarse para cargar la biblioteca restaurada. Tus datos anteriores se han conservado en una carpeta independiente."
          }
        }
      }
    },
