          }
        }
      }
    },
    "Your library will be moved to the Trash. Export a backup first if you might want it back.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的资料库将被移到废纸篓。如果以后可能还需要，请先导出备份。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您的資料庫將被移到垃圾桶。如果以後可能還需要，請先匯出備份。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリはゴミ箱に移動されます。後で元に戻す可能性がある場合は、先にバックアップをエクスポートしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "라이브러리가 휴지통으로 이동됩니다. 나중에 복구할 수도 있다면 먼저 백업을 내보내세요."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Bibliothek wird in den Papierkorb verschoben. Exportieren Sie zuerst ein Backup, falls Sie sie zurückhaben möchten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre bibliothèque sera placée dans la corbeille. Exportez d'abord une sauvegarde si vous pensez vouloir la récupérer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu biblioteca se moverá a la Papelera. Exporta primero una copia de seguridad por si quieres recuperarla."
          }
        }
      }
    },
    "Your saved API key and any sign-in for this provider will be permanently deleted. You'll need to re-enter them to use it again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此服务商已保存的 API 密钥及任何登录信息将被永久删除。再次使用时需要重新输入。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此服務商已儲存的 API 金鑰及任何登入資訊將被永久刪除。再次使用時需要重新輸入。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロバイダに保存された API キーとサインイン情報は完全に削除されます。再び使用するには再入力が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 제공자에 저장된 API 키와 로그인 정보가 영구적으로 삭제됩니다. 다시 사용하려면 재입력해야 합니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein gespeicherter API-Schlüssel und alle Anmeldungen für diesen Anbieter werden dauerhaft gelöscht. Du musst sie erneut eingeben, um ihn wieder zu verwenden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre clé API enregistrée et toute connexion pour ce fournisseur seront définitivement supprimées. Vous devrez les saisir à nouveau pour le réutiliser."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu clave API guardada y cualquier inicio de sesión para este proveedor se eliminarán permanentemente. Tendrás que volver a introducirlos para usarlo de nuevo."
          }
        }
      }
    },
