    "This will permanently delete this collection and all associated quiz cards. This action cannot be undone.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此操作将永久删除该分类及其所有相关的测验卡片。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將永久刪除此分類及所有相關的測驗卡。此動作無法復原。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このコレクションと関連するすべてのクイズカードを完全に削除します。この操作は取り消せません。"
          }
        },
        "ko": {
