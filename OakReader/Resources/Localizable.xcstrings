    "%@ items will be moved to the Bin. You can restore them later.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 个条目将被移到回收站。你之后可以恢复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 個項目將被移至垃圾桶。您稍後可以還原。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 個の項目をゴミ箱に入れます。後で復元できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "항목 %@개가 휴지통으로 이동됩니다. 나중에 복원할 수 있습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Objekte werden in den Papierkorb verschoben. Sie können sie später wiederherstellen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ éléments seront déplacés vers la corbeille. Vous pourrez les restaurer ultérieurement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ítems se moverán a la Papelera. Podrás restaurarlos más tarde."
          }
        }
      }
    },
    "%@ items will be permanently deleted. This cannot be undone.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 个条目将被永久删除。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 個項目將被永久刪除。此動作無法復原。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 個の項目を完全に削除します。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "항목 %@개가 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Objekte werden dauerhaft gelöscht. Dies kann nicht widerrufen werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ éléments seront supprimés définitivement. Cette action est irréversible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ítems se eliminarán permanentemente. Esta acción no se puede deshacer."
          }
        }
      }
    },
