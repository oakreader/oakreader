    "DuckDuckGo is used as a free fallback when no API key is configured.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未配置 API 密钥时，将使用 DuckDuckGo 作为免费备选。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未設定 API 金鑰時，將使用 DuckDuckGo 作為免費的備用方案。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "API キーが設定されていない場合は、無料のフォールバックとして DuckDuckGo が使用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "API 키가 구성되지 않은 경우 DuckDuckGo가 무료 대체 수단으로 사용됩니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DuckDuckGo wird als kostenlose Ausweichlösung verwendet, wenn kein API-Schlüssel konfiguriert ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "DuckDuckGo est utilisé comme solution de repli gratuite lorsqu’aucune clé API n’est configurée."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "DuckDuckGo se usa como alternativa gratuita cuando no hay ninguna clave API configurada."
          }
        }
