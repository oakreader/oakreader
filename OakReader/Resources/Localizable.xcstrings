    "Run an accessibility check to identify potential issues that may affect users with disabilities.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运行辅助功能检查，以发现可能影响残障用户的潜在问题。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "執行輔助使用檢查，以找出可能影響身心障礙使用者的潛在問題。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティチェックを実行して、障害のあるユーザーに影響する可能性のある問題を特定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "장애가 있는 사용자에게 영향을 줄 수 있는 잠재적 문제를 식별하려면 손쉬운 사용 검사를 실행하십시오."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Führen Sie eine Prüfung der Bedienungshilfen durch, um mögliche Probleme zu erkennen, die Nutzer mit Behinderungen beeinträchtigen könnten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancez une vérification de l’accessibilité pour identifier les problèmes potentiels susceptibles d’affecter les utilisateurs en situation de handicap."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta una comprobación de accesibilidad para identificar posibles problemas que puedan afectar a usuarios con discapacidad."
          }
        }
      }
    },
