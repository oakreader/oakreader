        }
      }
    },
    "This page has no headings\nto build a table of contents.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此页面没有标题\n无法构建目录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此頁面沒有標題\n可用以建立目錄。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
