    "%lld item(s) skipped — no extractable text (e.g. scanned PDFs)": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已跳过 %lld 个项目 — 无可提取的文本（例如扫描版 PDF）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已略過 %lld 個項目 — 無可擷取的文字（例如掃描版 PDF）"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 件の項目をスキップしました — 抽出可能なテキストがありません（例：スキャンされた PDF）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld개 항목을 건너뜀 — 추출 가능한 텍스트 없음(예: 스캔된 PDF)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld Objekt(e) übersprungen — kein extrahierbarer Text (z. B. gescannte PDFs)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld élément(s) ignoré(s) — aucun texte extractible (p. ex. PDF numérisés)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
