      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "指向代理或中转。以 `#` 结尾可按输入原样发送 URL。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "指向代理或中繼。以 `#` 結尾可按輸入原樣傳送 URL。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロキシまたはリレーを指定します。`#` で終えると入力したとおりに URL を送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프록시 또는 릴레이를 지정합니다. `#`로 끝내면 입력한 그대로 URL을 전송합니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
