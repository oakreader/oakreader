    "'%@' will be moved to the Bin. You can restore it later.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”将被移到回收站。你之后可以恢复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」將被移至垃圾桶。您稍後可以還原。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」をゴミ箱に入れます。後で復元できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@'이(가) 휴지통으로 이동됩니다. 나중에 복원할 수 있습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ wird in den Papierkorb verschoben. Sie können das Objekt später wiederherstellen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » sera déplacé vers la corbeille. Vous pourrez le restaurer ultérieurement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» se moverá a la Papelera. Podrás restaurarlo más tarde."
          }
        }
      }
    },
    "'%@' will be permanently deleted. This cannot be undone.": {
      "localizations": {
