    "Select which item to keep. Attachments and tags from the others will be transferred to it.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择要保留的条目。其他条目的附件和标签将转移到该条目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇要保留的項目。其他項目的附件與標籤將會轉移至此項目。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
