direction: right

title: {
  label: OakReader Database Schema
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

items: {
  shape: sql_table
  id: text {constraint: PK}
  user_id: text
  storage_key: text {constraint: UNIQUE}
  title: text
  author: text
  last_opened_at: text
  last_position: double
  sync_status: text
  cite_key: text {constraint: UNIQUE}
  source: text
  source_key: text
  extra: text
  processing_status: text
  created_at: text
  updated_at: text
}

attachments: {
  shape: sql_table
  id: text {constraint: PK}
  item_id: text {constraint: FK}
  storage_key: text {constraint: UNIQUE}
  file_name: text
  content_type: text
  link_mode: text
  source_url: text
  file_size: integer
  page_count: integer
  is_primary: integer
  created_at: text
  updated_at: text
}

collections: {
  shape: sql_table
  id: text {constraint: PK}
  user_id: text
  name: text
  "icon": text
  sort_order: integer
  parent_id: text {constraint: FK}
  is_smart: integer
  is_system: integer
  filter_rules: text
  source: text
  source_key: text
  created_at: text
  updated_at: text
}

collection_items: {
  shape: sql_table
  item_id: text {constraint: PK}
  collection_id: text {constraint: PK}
  created_at: text
}

properties: {
  shape: sql_table
  id: text {constraint: PK}
  name: text
  type: text
  "icon": text
  position: integer
  is_system: integer
}

property_options: {
  shape: sql_table
  id: text {constraint: PK}
  property_id: text {constraint: FK}
  name: text
  color_hex: text
  position: integer
}

item_property_values: {
  shape: sql_table
  id: text {constraint: PK}
  item_id: text {constraint: FK}
  property_id: text {constraint: FK}
  option_id: text {constraint: FK}
  text_value: text
}

conversations: {
  shape: sql_table
  id: text {constraint: PK}
  user_id: text
  item_id: text {constraint: FK}
  title: text
  message_count: integer
  created_at: text
  updated_at: text
}

notes: {
  shape: sql_table
  id: text {constraint: PK}
  user_id: text
  item_id: text {constraint: FK}
  title: text
  is_pinned: integer
  created_at: text
  updated_at: text
}

citations: {
  shape: sql_table
  item_id: text {constraint: PK}
  csl_json: text
  csl_type: text
  doi: text
  year: integer
  container_title: text
  abstract: text
  pmid: text
  arxiv_id: text
  isbn: text
  issn: text
  created_at: text
  updated_at: text
}

annotations: {
  shape: sql_table
  id: text {constraint: PK}
  user_id: text
  item_id: text {constraint: FK}
  attachment_id: text {constraint: FK}
  key: text {constraint: UNIQUE}
  type: text
  author_name: text
  text: text
  comment: text
  color: text
  page_label: text
  sort_index: text
  position_kind: text
  position_json: text
  style_json: text
  source: text
  source_key: text
  is_external: integer
  created_at: text
  updated_at: text
  deleted_at: text
}

quiz_cards: {
  shape: sql_table
  id: text {constraint: PK}
  item_id: text {constraint: FK}
  conversation_id: text
  group_id: text
  type: text
  content_json: text
  state: text
  due_at: text
  stability: double
  difficulty: double
  elapsed_days: integer
  scheduled_days: integer
  reps: integer
  lapses: integer
  last_review_at: text
  is_suspended: integer
  annotation_id: text
  source_text: text
  page_context: text
  is_pending: integer
  collection_id: text {constraint: FK}
  created_at: text
  updated_at: text
}

quiz_review_log: {
  shape: sql_table
  id: text {constraint: PK}
  card_id: text {constraint: FK}
  rating: integer
  state: text
  scheduled_days: integer
  elapsed_days: integer
  reviewed_at: text
}

item_relations: {
  shape: sql_table
  id: text {constraint: PK}
  source_item_id: text {constraint: FK}
  target_item_id: text {constraint: FK}
  relation_type: text
  created_at: text
}

items_fts: {
  shape: sql_table
  label: "items_fts (FTS5)"
  title: text
  author: text
}

citations_fts: {
  shape: sql_table
  label: "citations_fts (FTS5)"
  abstract: text
  container_title: text
}

# Relationships

attachments.item_id -> items.id
collection_items.item_id -> items.id
collection_items.collection_id -> collections.id
collections.parent_id -> collections.id: self {style.stroke-dash: 3}
property_options.property_id -> properties.id
item_property_values.item_id -> items.id
item_property_values.property_id -> properties.id
item_property_values.option_id -> property_options.id: {style.stroke-dash: 3}
conversations.item_id -> items.id: {style.stroke-dash: 3}
notes.item_id -> items.id
citations.item_id -> items.id
annotations.item_id -> items.id
annotations.attachment_id -> attachments.id
quiz_cards.item_id -> items.id
quiz_cards.collection_id -> collections.id: {style.stroke-dash: 3}
quiz_review_log.card_id -> quiz_cards.id
item_relations.source_item_id -> items.id
item_relations.target_item_id -> items.id
items_fts -> items: synced {style.stroke-dash: 5}
citations_fts -> citations: synced {style.stroke-dash: 5}
