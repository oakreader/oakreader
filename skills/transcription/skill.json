{
    "name": "transcription",
    "description": "Transcribe audio and video files",
    "icon": { "type": "symbol", "value": "waveform" },
    "requires": {
        "bins": [
            {
                "name": "whisper-cpp",
                "description": "Fast local speech-to-text transcription",
                "searchPaths": [
                    "~/Library/Application Support/OakReader/bin/whisper-cpp",
                    "/opt/homebrew/bin/whisper-cpp",
                    "/usr/local/bin/whisper-cpp"
                ],
                "install": { "brew": "whisper-cpp" },
                "versionArgs": ["--version"]
            }
        ]
    }
}
