{
    "icon": { "type": "symbol", "value": "globe.badge.chevron.backward" },
    "version": "1.0.0",
    "requires": {
        "bins": [
            {
                "name": "monolith",
                "description": "Save web pages as single HTML files",
                "searchPaths": [
                    "~/Library/Application Support/OakReader/bin/monolith",
                    "/opt/homebrew/bin/monolith",
                    "/usr/local/bin/monolith"
                ],
                "install": { "brew": "monolith" },
                "versionArgs": ["--version"]
            },
            {
                "name": "html-to-markdown",
                "description": "Convert HTML to clean Markdown for AI context",
                "searchPaths": [
                    "~/Library/Application Support/OakReader/bin/html-to-markdown",
                    "/opt/homebrew/bin/html-to-markdown",
                    "/usr/local/bin/html-to-markdown"
                ],
                "install": { "brew": "kreuzberg-dev/tap/html-to-markdown" },
                "versionArgs": ["--version"]
            }
        ]
    }
}
