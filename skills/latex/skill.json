{
    "icon": { "type": "symbol", "value": "doc.richtext.fill" },
    "version": "1.0.0",
    "requires": {
        "bins": [
            {
                "name": "tectonic",
                "description": "Self-contained LaTeX engine written in Rust",
                "searchPaths": [
                    "~/Library/Application Support/OakReader/bin/tectonic",
                    "/opt/homebrew/bin/tectonic",
                    "/usr/local/bin/tectonic"
                ],
                "install": {
                    "brew": "tectonic",
                    "url": "https://github.com/tectonic-typesetting/tectonic/releases/latest/download/tectonic-0.15.0-aarch64-apple-darwin.tar.gz"
                },
                "versionArgs": ["--version"]
            }
        ]
    }
}
