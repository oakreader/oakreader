# Xcode
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.xcworkspace/xcuserdata/

# Per-developer local code-signing override (your own team / ad-hoc identity).
# Never commit it — it is meant to override the maintainer defaults in
# xcconfig/OakReader-common.xcconfig. Copy DeveloperSettings.example.xcconfig
# or run scripts/setup-signing.sh.
xcconfig/DeveloperSettings.xcconfig

# Build
build/
.build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.swiftpm/
Package.resolved
# ...except the Xcode project's resolved versions — committed so CI pins the
# same dependency versions as local (e.g. usearch 2.16.10, which has .F32).
!OakReader.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# CocoaPods (if ever used)
Pods/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# OS files
.DS_Store
*.swp
*~
._*
Thumbs.db

# Claude Code
.claude/

# IDE
*.idea/
*.vscode/

# Archives
*.xcarchive

# Provisioning
*.mobileprovision
*.provisionprofile

# Browser Extension
browser-extension/node_modules/
browser-extension/.output/
browser-extension/.wxt/

# TTS samples
tts_samples/

# Temp files
tmp/

# Agent runtime state
.agmod/

# Cloudflare Wrangler
.wrangler/

# Dia reference app (local analysis copy)
/Dia/

# Keys and secrets
*.pem
*.p12
*.key
*.env
*.env.*

# Internal-only docs (release runbook, prompt sessions) — kept local, not published
docs/internal/
