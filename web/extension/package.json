{
  "name": "oakreader-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OakReader browser extension (WXT) — saves web pages/articles to the desktop app.",
  "scripts": {
    "build:singlefile": "rollup -c rollup.singlefile.config.js",
    "dev": "pnpm run build:singlefile && wxt",
    "build": "pnpm run build:singlefile && wxt build",
    "zip": "pnpm run build:singlefile && wxt zip",
    "prepare": "wxt prepare"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "defuddle": "^0.18.1",
    "lucide-react": "^1.14.0",
    "react": "^19",
    "react-dom": "^19",
    "single-file-core": "^1.5.84",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "rollup": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.0",
    "wxt": "^0.20.0"
  }
}
